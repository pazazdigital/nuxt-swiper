{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    ".nuxt",
    ".output",
    "examples",
    "test/fixtures/**/.nuxt"
  ],
  "rules": {
    "no-console": "off",
    "no-underscore-dangle": "off"
  }
}
