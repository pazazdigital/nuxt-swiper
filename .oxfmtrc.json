{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "semi": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 100,
  "jsdoc": true,
  "sortTailwindcss": true,
  "sortImports": true,
  "ignorePatterns": [
    "dist",
    "node_modules",
    ".nuxt",
    ".output",
    "pnpm-lock.yaml",
    "examples",
    "test/fixtures/**/.nuxt"
  ]
}
